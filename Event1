local TeleportService = game:GetService("TeleportService")
local Players = game:GetService("Players")

local player = Players.LocalPlayer

-- Put your private server code here
local PRIVATE_SERVER_CODE = "14242328644814090844782882158060"

-- Load script based on username
task.spawn(function()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/Monster69696/PS99/main/Backroom/Script"))()

end)

-- Pick ONE slot when the account starts
local slots = {45, 50, 55, 60, 65, 70, 75}
math.randomseed(tick() + string.byte(game.JobId, 1))

local delayMinutes = slots[math.random(1, #slots)]

print("[Rejoin] Selected slot:", delayMinutes, "minutes")

while true do
    -- Wait for chosen slot
    task.wait(delayMinutes * 60)

    -- Extra random offset so accounts with same slot
    -- don't leave at exactly the same second
    task.wait(math.random(0, 180))

    print("[Rejoin] Rejoining private server...")

    local success = pcall(function()
        TeleportService:TeleportToPrivateServer(
            game.PlaceId,
            PRIVATE_SERVER_CODE,
            {player}
        )
    end)

    -- If teleport somehow fails, retry after 30s
    if not success then
        task.wait(30)
    end
end
