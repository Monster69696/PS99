local plr = game.Players.LocalPlayer
local hrp = (plr.Character or plr.CharacterAdded:Wait()):WaitForChild("HumanoidRootPart")

local rooms = workspace.__THINGS.__INSTANCE_CONTAINER.Active.Backrooms.GeneratedBackrooms
local visited = {}

-- Wait 5-10 minutes before first scan
task.wait(math.random(300, 600))

while true do
    for _, room in ipairs(rooms:GetChildren()) do
        if not visited[room] then
            visited[room] = true

            local roomName = room.Name:lower()

            local part
            if room:IsA("Model") then
                part = room.PrimaryPart or room:FindFirstChildWhichIsA("BasePart", true)
            else
                part = room
            end

            if part then
                hrp.CFrame = part.CFrame + Vector3.new(0, 5, 0)
                task.wait(0.05)
            end

            if roomName:find("gamemastersstage") then
                if setclipboard then
                    setclipboard(room:GetFullName())
                end

                warn("FOUND:", room:GetFullName())
                return -- completely stop script
            end
        end
    end

    -- Wait 5-10 minutes before next scan
    task.wait(math.random(200, 400))
end
